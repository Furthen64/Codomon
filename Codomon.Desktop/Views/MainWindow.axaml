<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Codomon.Desktop.Views.MainWindow"
        Title="Codomon"
        Width="1280" Height="800"
        MinWidth="800" MinHeight="600"
        WindowStartupLocation="CenterScreen">

  <DockPanel LastChildFill="True">

    <!-- Top Toolbar -->
    <Border DockPanel.Dock="Top" Background="#1E2A3A" BorderThickness="0,0,0,1" BorderBrush="#2A3F5A" Padding="4">
      <StackPanel Orientation="Horizontal" Spacing="6">
        <Button Content="New Workspace"  Click="OnNewWorkspaceClick"  Padding="10,4"/>
        <Button Content="Open Workspace" Click="OnOpenWorkspaceClick" Padding="10,4"/>
        <Button Content="Save"           Click="OnSaveWorkspaceClick" Padding="10,4"/>
        <Button Content="Save As…"       Click="OnSaveAsWorkspaceClick" Padding="10,4"/>
        <Separator Width="1" Background="#2A3F5A" Margin="4,0"/>
        <Button Content="Scan"           Padding="10,4"/>
        <Button Content="Run"            Padding="10,4"/>
        <Button Content="Replay Logs"    Padding="10,4"/>
        <Separator Width="1" Background="#2A3F5A" Margin="4,0"/>
        <Button Content="Load Autosave"  Click="OnLoadAutosaveClick" Padding="10,4"/>
        <Separator Width="1" Background="#2A3F5A" Margin="4,0"/>
        <TextBlock Text="Profile:" Foreground="#AABBCC" VerticalAlignment="Center" Margin="4,0,2,0"/>
        <ComboBox x:Name="ProfileComboBox" Width="150" Padding="6,2"
                  SelectionChanged="OnProfileComboBoxSelectionChanged"/>
        <Button Content="New"       Click="OnNewProfileClick"       Padding="8,4"/>
        <Button Content="Rename"    Click="OnRenameProfileClick"    Padding="8,4"/>
        <Button Content="Duplicate" Click="OnDuplicateProfileClick" Padding="8,4"/>
        <Separator Width="1" Background="#2A3F5A" Margin="4,0"/>
        <Button Content="Dev Console"    Click="OnDevConsoleClick" Padding="10,4"/>
      </StackPanel>
    </Border>

    <!-- Status Bar -->
    <Border DockPanel.Dock="Bottom" Background="#111820" Padding="8,3" BorderThickness="0,1,0,0" BorderBrush="#2A3F5A">
      <TextBlock x:Name="StatusText" Text="Ready" Foreground="#88AABB" FontSize="11"/>
    </Border>

    <!-- Bottom Panel (Logs / Timeline) -->
    <Border DockPanel.Dock="Bottom" Height="170" Background="#141C28" BorderThickness="0,1,0,0" BorderBrush="#2A3F5A">
      <TabControl>
        <TabItem Header="Logs">
          <ListBox Background="Transparent" x:Name="LogsListBox">
            <ListBoxItem>
              <TextBlock Foreground="#88CCAA" FontFamily="Monospace" Text="[INFO]  App started"/>
            </ListBoxItem>
            <ListBoxItem>
              <TextBlock Foreground="#88CCAA" FontFamily="Monospace" Text="[INFO]  Demo data loaded: 3 systems, 5 modules"/>
            </ListBoxItem>
            <ListBoxItem>
              <TextBlock Foreground="#AAAAAA" FontFamily="Monospace" Text="[DEBUG] Canvas initialized"/>
            </ListBoxItem>
          </ListBox>
        </TabItem>
        <TabItem Header="Timeline">
          <TextBlock Text="Timeline — no events recorded yet." 
                     Foreground="#888888" Margin="12" VerticalAlignment="Center"/>
        </TabItem>
      </TabControl>
    </Border>

    <!-- Main 3-column area -->
    <Grid>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="250"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="300"/>
      </Grid.ColumnDefinitions>

      <!-- Left Panel: TreeView -->
      <Border Grid.Column="0" Background="#141C28" BorderThickness="0,0,1,0" BorderBrush="#2A3F5A">
        <DockPanel>
          <Border DockPanel.Dock="Top" Padding="8,6" Background="#1A2435">
            <TextBlock Text="Architecture" FontWeight="Bold" Foreground="#AABBCC"/>
          </Border>
          <TreeView x:Name="ArchTreeView" Background="Transparent" Margin="4"/>
        </DockPanel>
      </Border>

      <!-- Center Panel: Canvas -->
      <Border Grid.Column="1" Background="#0F141E" ClipToBounds="True">
        <DockPanel>
          <Border DockPanel.Dock="Top" Padding="8,6" Background="#1A2435">
            <TextBlock Text="Canvas" FontWeight="Bold" Foreground="#AABBCC"/>
          </Border>
          <ContentControl x:Name="CanvasHost" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch"/>
        </DockPanel>
      </Border>

      <!-- Right Panel: Properties -->
      <Border Grid.Column="2" Background="#141C28" BorderThickness="1,0,0,0" BorderBrush="#2A3F5A">
        <DockPanel>
          <Border DockPanel.Dock="Top" Padding="8,6" Background="#1A2435">
            <TextBlock Text="Properties" FontWeight="Bold" Foreground="#AABBCC"/>
          </Border>
          <StackPanel Margin="10" Spacing="8">
            <TextBlock Text="Selected Item" Foreground="#778899" FontSize="11"/>
            <StackPanel Spacing="4">
              <TextBlock Text="Name:" Foreground="#AABBCC" FontWeight="SemiBold"/>
              <TextBlock x:Name="PropNameText" Text="None" Foreground="White" Margin="0,0,0,8"/>
              <TextBlock Text="Type:" Foreground="#AABBCC" FontWeight="SemiBold"/>
              <TextBlock x:Name="PropTypeText" Text="-" Foreground="White"/>
            </StackPanel>
          </StackPanel>
        </DockPanel>
      </Border>
    </Grid>

  </DockPanel>
</Window>
