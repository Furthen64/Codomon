<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:nodify="https://miroiu.github.io/nodify"
             xmlns:vm="clr-namespace:Codomon.Desktop.ViewModels"
             x:Class="Codomon.Desktop.Views.GraphView"
             x:DataType="vm:GraphViewModel">

  <DockPanel>

    <!-- ── Canvas Alignment Toolbar ──────────────────────────────────────── -->
    <Border DockPanel.Dock="Top"
            Background="#1A2435"
            BorderThickness="0,0,0,1"
            BorderBrush="#2A3F5A"
            Padding="6,4">
      <StackPanel Orientation="Horizontal" Spacing="8">

        <!-- VIEW group: fit / zoom -->
        <Border BorderBrush="#2A3F5A" BorderThickness="1" CornerRadius="4" Padding="6,3">
          <StackPanel Spacing="3">
            <TextBlock Text="VIEW" FontSize="9" FontWeight="Bold" Foreground="#4A6A8A"
                       LetterSpacing="1" HorizontalAlignment="Center"/>
            <StackPanel Orientation="Horizontal" Spacing="3">
              <Button x:Name="FitToViewButton" Content="⊡ Fit"  Padding="7,2"
                      ToolTip.Tip="Fit all nodes into view"/>
              <Button x:Name="ZoomInButton"    Content="+"       Padding="7,2"
                      ToolTip.Tip="Zoom in"/>
              <Button x:Name="ZoomOutButton"   Content="−"       Padding="7,2"
                      ToolTip.Tip="Zoom out"/>
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- ALIGN group: align edges / centers of selected nodes -->
        <Border BorderBrush="#2A3F5A" BorderThickness="1" CornerRadius="4" Padding="6,3">
          <StackPanel Spacing="3">
            <TextBlock Text="ALIGN SELECTED" FontSize="9" FontWeight="Bold" Foreground="#4A6A8A"
                       LetterSpacing="1" HorizontalAlignment="Center"/>
            <StackPanel Orientation="Horizontal" Spacing="3">
              <Button x:Name="AlignLeftButton"   Content="◀ Left"   Padding="7,2"
                      ToolTip.Tip="Align left edges of selected nodes"/>
              <Button x:Name="AlignRightButton"  Content="Right ▶"  Padding="7,2"
                      ToolTip.Tip="Align right edges of selected nodes"/>
              <Button x:Name="AlignTopButton"    Content="▲ Top"    Padding="7,2"
                      ToolTip.Tip="Align top edges of selected nodes"/>
              <Button x:Name="AlignBottomButton" Content="▼ Bot"    Padding="7,2"
                      ToolTip.Tip="Align bottom edges of selected nodes"/>
              <Button x:Name="CenterHButton"     Content="↕ Ctr H"  Padding="7,2"
                      ToolTip.Tip="Center selected nodes on a shared horizontal axis"/>
              <Button x:Name="CenterVButton"     Content="↔ Ctr V"  Padding="7,2"
                      ToolTip.Tip="Center selected nodes on a shared vertical axis"/>
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- ARRANGE group: automatic layout / distribution -->
        <Border BorderBrush="#2A3F5A" BorderThickness="1" CornerRadius="4" Padding="6,3">
          <StackPanel Spacing="3">
            <TextBlock Text="ARRANGE" FontSize="9" FontWeight="Bold" Foreground="#4A6A8A"
                       LetterSpacing="1" HorizontalAlignment="Center"/>
            <StackPanel Orientation="Horizontal" Spacing="3">
              <Button x:Name="AutoAlignButton"   Content="⊞ Auto-Align"  Padding="7,2"
                      ToolTip.Tip="Arrange all nodes left-to-right in connection order, then fit to view"/>
              <Button x:Name="DistributeHButton" Content="⇔ Space H"     Padding="7,2"
                      ToolTip.Tip="Evenly distribute selected nodes along the horizontal axis (select 3 or more)"/>
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- FILTER group: confidence + relationship-kind toggles -->
        <Border BorderBrush="#2A3F5A" BorderThickness="1" CornerRadius="4" Padding="6,3">
          <StackPanel Spacing="3">
            <TextBlock Text="FILTER" FontSize="9" FontWeight="Bold" Foreground="#4A6A8A"
                       LetterSpacing="1" HorizontalAlignment="Center"/>
            <StackPanel Orientation="Horizontal" Spacing="6">
              <CheckBox x:Name="FilterLowConfidenceCheck" Content="Low Conf"
                        FontSize="11" Foreground="#AABBCC"
                        ToolTip.Tip="Show items with Unknown confidence (hidden by default)"/>
              <CheckBox x:Name="FilterCallsCheck" Content="Calls"
                        IsChecked="True" FontSize="11" Foreground="#AABBCC"
                        ToolTip.Tip="Show Calls relationships"/>
              <CheckBox x:Name="FilterDependsCheck" Content="Depends"
                        IsChecked="True" FontSize="11" Foreground="#AABBCC"
                        ToolTip.Tip="Show Depends relationships"/>
              <CheckBox x:Name="FilterImportsCheck" Content="Imports"
                        IsChecked="True" FontSize="11" Foreground="#AABBCC"
                        ToolTip.Tip="Show Imports relationships"/>
              <CheckBox x:Name="FilterOtherKindsCheck" Content="Others"
                        IsChecked="True" FontSize="11" Foreground="#AABBCC"
                        ToolTip.Tip="Show all other relationship kinds (Configures, Logs, Hosts, …)"/>
            </StackPanel>
          </StackPanel>
        </Border>

      </StackPanel>
    </Border>

    <!-- ── Graph Canvas ───────────────────────────────────────────────────── -->
    <nodify:NodifyEditor x:Name="Editor"
                         ItemsSource="{Binding Nodes}"
                         Connections="{Binding Connections}">

      <!-- Node template: explicit left-side inputs and right-side outputs -->
      <nodify:NodifyEditor.ItemTemplate>
        <DataTemplate x:DataType="vm:NodeViewModel">
          <nodify:Node Header="{Binding Title}"
                       Input="{Binding Inputs}"
                       Output="{Binding Outputs}"
                       BorderThickness="{Binding BorderThickness}">

            <!-- Each input connector rendered as a NodeInput on the left -->
            <nodify:Node.InputConnectorTemplate>
              <DataTemplate x:DataType="vm:ConnectorViewModel">
                <nodify:NodeInput Anchor="{Binding Anchor, Mode=OneWayToSource}"
                                  IsConnected="{Binding IsConnected}" />
              </DataTemplate>
            </nodify:Node.InputConnectorTemplate>

            <!-- Each output connector rendered as a NodeOutput on the right -->
            <nodify:Node.OutputConnectorTemplate>
              <DataTemplate x:DataType="vm:ConnectorViewModel">
                <nodify:NodeOutput Anchor="{Binding Anchor, Mode=OneWayToSource}"
                                   IsConnected="{Binding IsConnected}" />
              </DataTemplate>
            </nodify:Node.OutputConnectorTemplate>

          </nodify:Node>
        </DataTemplate>
      </nodify:NodifyEditor.ItemTemplate>

      <!-- Position each ItemContainer at the node's Location.
           ReflectionBinding is used because ControlTheme bindings cannot resolve
           the DataContext type statically when compiled bindings are enabled globally. -->
      <nodify:NodifyEditor.ItemContainerTheme>
        <ControlTheme TargetType="nodify:ItemContainer" BasedOn="{StaticResource {x:Type nodify:ItemContainer}}">
          <Setter Property="Location" Value="{ReflectionBinding Location}" />
        </ControlTheme>
      </nodify:NodifyEditor.ItemContainerTheme>

      <!-- Connection template: cubic bezier curve; Label is shown as a tooltip. -->
      <nodify:NodifyEditor.ConnectionTemplate>
        <DataTemplate x:DataType="vm:ConnectionViewModel">
          <nodify:Connection Source="{Binding Source}"
                             Target="{Binding Target}"
                             Stroke="#80B4D4"
                             StrokeThickness="2"
                             ToolTip.Tip="{Binding Label}" />
        </DataTemplate>
      </nodify:NodifyEditor.ConnectionTemplate>

    </nodify:NodifyEditor>

  </DockPanel>

</UserControl>
