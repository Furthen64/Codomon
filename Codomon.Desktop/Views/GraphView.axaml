<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:nodify="https://miroiu.github.io/nodify"
             xmlns:vm="clr-namespace:Codomon.Desktop.ViewModels"
             x:Class="Codomon.Desktop.Views.GraphView"
             x:DataType="vm:GraphViewModel">

  <nodify:NodifyEditor ItemsSource="{Binding Nodes}"
                       Connections="{Binding Connections}">

    <!-- Node template: explicit left-side inputs and right-side outputs -->
    <nodify:NodifyEditor.ItemTemplate>
      <DataTemplate x:DataType="vm:NodeViewModel">
        <nodify:Node Header="{Binding Title}"
                     Input="{Binding Inputs}"
                     Output="{Binding Outputs}">

          <!-- Each input connector rendered as a NodeInput on the left -->
          <nodify:Node.InputConnectorTemplate>
            <DataTemplate x:DataType="vm:ConnectorViewModel">
              <nodify:NodeInput Anchor="{Binding Anchor, Mode=OneWayToSource}"
                                IsConnected="{Binding IsConnected}" />
            </DataTemplate>
          </nodify:Node.InputConnectorTemplate>

          <!-- Each output connector rendered as a NodeOutput on the right -->
          <nodify:Node.OutputConnectorTemplate>
            <DataTemplate x:DataType="vm:ConnectorViewModel">
              <nodify:NodeOutput Anchor="{Binding Anchor, Mode=OneWayToSource}"
                                 IsConnected="{Binding IsConnected}" />
            </DataTemplate>
          </nodify:Node.OutputConnectorTemplate>

        </nodify:Node>
      </DataTemplate>
    </nodify:NodifyEditor.ItemTemplate>

    <!-- Position each ItemContainer at the node's Location.
         ReflectionBinding is used because ControlTheme bindings cannot resolve
         the DataContext type statically when compiled bindings are enabled globally. -->
    <nodify:NodifyEditor.ItemContainerTheme>
      <ControlTheme TargetType="nodify:ItemContainer" BasedOn="{StaticResource {x:Type nodify:ItemContainer}}">
        <Setter Property="Location" Value="{ReflectionBinding Location}" />
      </ControlTheme>
    </nodify:NodifyEditor.ItemContainerTheme>

    <!-- Connection template: cubic bezier curve, slightly thicker, soft light-blue stroke -->
    <nodify:NodifyEditor.ConnectionTemplate>
      <DataTemplate x:DataType="vm:ConnectionViewModel">
        <nodify:Connection Source="{Binding Source}"
                           Target="{Binding Target}"
                           Stroke="#80B4D4"
                           StrokeThickness="2" />
      </DataTemplate>
    </nodify:NodifyEditor.ConnectionTemplate>

  </nodify:NodifyEditor>

</UserControl>
