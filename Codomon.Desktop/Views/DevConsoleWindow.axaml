<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Codomon.Desktop.Views.DevConsoleWindow"
        Title="Dev Console"
        Width="700" Height="440"
        MinWidth="500" MinHeight="280"
        WindowStartupLocation="CenterOwner"
        Background="#0D1117">

  <DockPanel LastChildFill="True">

    <!-- Toolbar -->
    <Border DockPanel.Dock="Top" Background="#161B22"
            BorderThickness="0,0,0,1" BorderBrush="#2A3F5A" Padding="8,5">
      <StackPanel Orientation="Horizontal" Spacing="8">
        <Button x:Name="ClearButton" Content="Clear" Click="OnClearClick" Padding="10,3"/>
        <TextBlock Text="Filter:" Foreground="#88AABB" VerticalAlignment="Center"/>
        <TextBox x:Name="FilterBox" Width="180" Watermark="type to filter…"
                 TextChanged="OnFilterChanged" Padding="6,3" Background="#1C2128" Foreground="White"/>
      </StackPanel>
    </Border>

    <!-- Log list — single TextBox so the user can select and copy across multiple lines -->
    <TextBox x:Name="LogBox"
             Background="#0D1117"
             Foreground="#88CCAA"
             FontFamily="Monospace"
             FontSize="12"
             IsReadOnly="True"
             AcceptsReturn="True"
             TextWrapping="NoWrap"
             ScrollViewer.HorizontalScrollBarVisibility="Auto"
             ScrollViewer.VerticalScrollBarVisibility="Auto"
             Padding="8,4"
             BorderThickness="0"/>

  </DockPanel>
</Window>
