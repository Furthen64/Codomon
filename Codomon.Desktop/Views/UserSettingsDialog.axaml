<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Codomon.Desktop.Views.UserSettingsDialog"
        Title="User Settings"
        Width="700" Height="800"
        MinWidth="560" MinHeight="520"
        CanResize="True"
        WindowStartupLocation="CenterOwner"
        Background="#111820">

  <DockPanel LastChildFill="True">

    <!-- Header bar -->
    <Border DockPanel.Dock="Top" Background="#1E2A3A"
            BorderThickness="0,0,0,1" BorderBrush="#2A3F5A" Padding="16,12">
      <StackPanel Spacing="2">
        <TextBlock Text="User Settings" FontSize="16" FontWeight="Bold" Foreground="White"/>
        <TextBlock Text="Application-wide preferences stored in your user application data directory."
                   FontSize="12" Foreground="#88AABB"/>
        <TextBlock x:Name="ConfigPathText" Text=""
                   FontSize="11" Foreground="#6F8CA8"/>
      </StackPanel>
    </Border>

    <!-- Bottom button bar -->
    <Border DockPanel.Dock="Bottom" Background="#1E2A3A"
            BorderThickness="0,1,0,0" BorderBrush="#2A3F5A" Padding="16,10">
      <DockPanel>
        <Button Content="Cancel" Click="OnCancelClick" Padding="16,6" DockPanel.Dock="Left"/>
        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
          <TextBlock x:Name="SaveStatusText" Text="" Foreground="#88AABB" FontSize="11"
                     VerticalAlignment="Center"/>
          <Button x:Name="SaveButton" Content="Save Settings" Click="OnSaveClick"
                  Padding="16,6" Background="#1A3A5A" Foreground="White"/>
          <Button x:Name="OkButton" Content="OK" Click="OnOkClick"
                  Padding="16,6" IsEnabled="False"/>
        </StackPanel>
      </DockPanel>
    </Border>

    <!-- Content area -->
    <ScrollViewer VerticalScrollBarVisibility="Auto">
      <StackPanel Margin="24,18" Spacing="20">

        <!-- Section: Default LLM Settings -->
        <StackPanel Spacing="4">
          <TextBlock Text="DEFAULT LLM SETTINGS" FontSize="9" FontWeight="Bold"
                     Foreground="#4A6A8A" LetterSpacing="1"/>
          <TextBlock Text="These values are used as defaults when a workspace has no LLM endpoint or model configured."
                     Foreground="#556677" FontSize="11" TextWrapping="Wrap"/>
        </StackPanel>

        <!-- API Endpoint -->
        <StackPanel Spacing="6">
          <TextBlock Text="API Endpoint" Foreground="#AABBCC" FontWeight="SemiBold"/>
          <TextBlock Text="Base URL of your OpenAI-compatible endpoint (e.g. http://localhost:8080/v1)"
                     Foreground="#556677" FontSize="11"/>
          <TextBox x:Name="ApiEndpointBox"
                   Watermark="http://localhost:8080/v1"/>
        </StackPanel>

        <!-- Model Name -->
        <StackPanel Spacing="6">
          <TextBlock Text="Model Name" Foreground="#AABBCC" FontWeight="SemiBold"/>
          <TextBlock Text="Type a model name, or click Probe Models to fetch available models from the host."
                     Foreground="#556677" FontSize="11" TextWrapping="Wrap"/>
          <Grid ColumnDefinitions="*,Auto">
            <TextBox x:Name="ModelNameBox" Grid.Column="0"
                     Watermark="model name…"/>
            <Button x:Name="ProbeModelsButton" Content="Probe Models" Grid.Column="1"
                    Click="OnProbeModelsClick" Padding="10,5" Margin="8,0,0,0"/>
          </Grid>
          <ComboBox x:Name="ModelPickerComboBox"
                    PlaceholderText="- select from probed models -"
                    HorizontalAlignment="Stretch"
                    IsEnabled="False"
                    SelectionChanged="OnModelPickerSelectionChanged"/>
          <TextBlock x:Name="ProbeStatusText" Text="" Foreground="#AABBCC" FontSize="11"/>
        </StackPanel>

        <!-- Test Connection -->
        <StackPanel Spacing="8">
          <StackPanel Orientation="Horizontal" Spacing="10">
            <Button x:Name="TestConnectionButton" Content="Test Connection"
                    Click="OnTestConnectionClick" Padding="14,5"/>
            <TextBlock x:Name="ConnectionStatusText"
                       Text="" VerticalAlignment="Center"
                       Foreground="#AABBCC" FontSize="12" TextWrapping="Wrap"/>
          </StackPanel>
        </StackPanel>

        <!-- Divider -->
        <Border Height="1" Background="#1E2A3A" Margin="0,4"/>

        <!-- Section: Autosave Settings -->
        <StackPanel Spacing="4">
          <TextBlock Text="AUTOSAVE SETTINGS" FontSize="9" FontWeight="Bold"
                     Foreground="#4A6A8A" LetterSpacing="1"/>
          <TextBlock Text="Controls how often workspaces are auto-saved and how many snapshots are kept."
                     Foreground="#556677" FontSize="11" TextWrapping="Wrap"/>
        </StackPanel>

        <Grid ColumnDefinitions="*,24,*">
          <StackPanel Grid.Column="0" Spacing="6">
            <TextBlock Text="Autosave interval (minutes)" Foreground="#AABBCC" FontWeight="SemiBold"/>
            <TextBlock Text="How often a snapshot is created while a workspace is open. Minimum 1."
                       Foreground="#556677" FontSize="11" TextWrapping="Wrap"/>
            <NumericUpDown x:Name="AutosaveIntervalBox"
                           Minimum="1" Maximum="120" Increment="1" FormatString="0"
                           Watermark="5"/>
          </StackPanel>
          <StackPanel Grid.Column="2" Spacing="6">
            <TextBlock Text="Maximum autosave snapshots" Foreground="#AABBCC" FontWeight="SemiBold"/>
            <TextBlock Text="Oldest snapshots beyond this limit are deleted automatically. Minimum 1."
                       Foreground="#556677" FontSize="11" TextWrapping="Wrap"/>
            <NumericUpDown x:Name="MaxAutosavesBox"
                           Minimum="1" Maximum="100" Increment="1" FormatString="0"
                           Watermark="10"/>
          </StackPanel>
        </Grid>

        <!-- Divider -->
        <Border Height="1" Background="#1E2A3A" Margin="0,4"/>

        <!-- Section: Recent Workspaces -->
        <StackPanel Spacing="4">
          <TextBlock Text="RECENT WORKSPACES" FontSize="9" FontWeight="Bold"
                     Foreground="#4A6A8A" LetterSpacing="1"/>
        </StackPanel>

        <StackPanel Spacing="6">
          <TextBlock Text="Maximum recent workspace entries" Foreground="#AABBCC" FontWeight="SemiBold"/>
          <TextBlock Text="Number of workspaces shown in the recent-workspaces list on the welcome screen."
                     Foreground="#556677" FontSize="11" TextWrapping="Wrap"/>
          <NumericUpDown x:Name="MaxRecentWorkspacesBox"
                         Minimum="1" Maximum="200" Increment="1" FormatString="0"
                         Watermark="20" HorizontalAlignment="Left" MinWidth="120"/>
        </StackPanel>

        <!-- Divider -->
        <Border Height="1" Background="#1E2A3A" Margin="0,4"/>

        <!-- Section: Log Replay -->
        <StackPanel Spacing="4">
          <TextBlock Text="LOG REPLAY" FontSize="9" FontWeight="Bold"
                     Foreground="#4A6A8A" LetterSpacing="1"/>
        </StackPanel>

        <StackPanel Spacing="6">
          <TextBlock Text="Default replay speed" Foreground="#AABBCC" FontWeight="SemiBold"/>
          <TextBlock Text="Playback speed pre-selected when the replay toolbar is opened."
                     Foreground="#556677" FontSize="11"/>
          <ComboBox x:Name="DefaultReplaySpeedComboBox" HorizontalAlignment="Left" MinWidth="120"/>
        </StackPanel>

        <!-- Divider -->
        <Border Height="1" Background="#1E2A3A" Margin="0,4"/>

        <!-- Section: Log Import Defaults -->
        <StackPanel Spacing="4">
          <TextBlock Text="LOG IMPORT DEFAULTS" FontSize="9" FontWeight="Bold"
                     Foreground="#4A6A8A" LetterSpacing="1"/>
          <TextBlock Text="These options are pre-selected when opening the Import Wizard."
                     Foreground="#556677" FontSize="11" TextWrapping="Wrap"/>
        </StackPanel>

        <Grid ColumnDefinitions="*,16,*">
          <StackPanel Grid.Column="0" Spacing="6">
            <TextBlock Text="Default delimiter" Foreground="#AABBCC" FontWeight="SemiBold"/>
            <ComboBox x:Name="DefaultDelimiterComboBox" HorizontalAlignment="Stretch"/>
          </StackPanel>
          <StackPanel Grid.Column="2" Spacing="6">
            <TextBlock Text="Default known format" Foreground="#AABBCC" FontWeight="SemiBold"/>
            <ComboBox x:Name="DefaultKnownFormatComboBox" HorizontalAlignment="Stretch"/>
          </StackPanel>
        </Grid>

        <Grid ColumnDefinitions="*,16,*" Margin="0,10,0,0">
          <StackPanel Grid.Column="0" Spacing="6">
            <TextBlock Text="Default timestamp format" Foreground="#AABBCC" FontWeight="SemiBold"/>
            <ComboBox x:Name="DefaultTimestampFormatComboBox" HorizontalAlignment="Stretch"/>
          </StackPanel>
          <StackPanel Grid.Column="2" Spacing="6">
            <TextBlock Text="Default time zone" Foreground="#AABBCC" FontWeight="SemiBold"/>
            <ComboBox x:Name="DefaultTimeZoneComboBox" HorizontalAlignment="Stretch"/>
          </StackPanel>
        </Grid>

      </StackPanel>
    </ScrollViewer>

  </DockPanel>
</Window>
